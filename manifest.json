{
    "manifest_version": 3,
    "name": "ComickSync",
    "version": "1.0",
    "description": "Sync your manga reading progress to Comick",
    "author": "GooglyBlox",
    "permissions": [
        "cookies",
        "storage",
        "tabs",
        "scripting",
        "alarms",
        "notifications"
    ],
    "host_permissions": [
        "*://comick.dev/*",
        "*://api.comick.dev/*",
        "*://chibi.malsync.moe/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": [
                "content/detector.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "chibi/evaluator.js",
                "icons/icon128.png"
            ],
            "matches": ["<all_urls>"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}
